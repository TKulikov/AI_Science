# Yandex AI Studio (обязательно)
FOLDER_ID=ваш_folder_id
API_KEY=ваш_api_key

# Потоковая загрузка (память)
LOAD_BATCH_SIZE=50 # документов в батче; меньше = меньше RAM
MAX_FILE_MB=60 # файлы крупнее пропускаются
SCAN_PROBE_PAGES=3
SCAN_MIN_CHARS_PER_PAGE=50

# Граф 
KG_NUM_WORKERS=8
KG_MAX_TRIPLETS=15
KG_EMBED_NODES=false
CHUNK_SIZE=500
CHUNK_OVERLAP=128
